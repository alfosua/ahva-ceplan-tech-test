@using System.Security.Claims
@using Microsoft.Extensions.Options
@inject IOptions<SecurityOptions> Security
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPLAN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-page"
      data-session-ms="@(Security.Value.SessionExpirationMinutes * 60_000)"
      data-session-warn-ms="@(Security.Value.SessionWarningSeconds * 1_000)">
    <aside class="sidebar" id="sidebar">
        <button type="button" class="sidebar-toggle" id="sidebar-toggle" title="Menú">
            <span></span><span></span><span></span>
        </button>
        <nav class="sidebar-nav">
            <a class="sidebar-item" href="#" title="Inicio" data-wip>
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m4 11 8-7 8 7" /><path d="M6 9.5V20h12V9.5" />
                </svg>
                <span class="sidebar-label">Inicio</span>
            </a>
            <a class="sidebar-item" href="#" title="Entidades" data-wip>
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="4" y="7" width="9" height="13" /><path d="M13 11h7v9h-7" /><path d="M7 11h3M7 14.5h3M7 18h3M16 14.5h2M16 18h2" />
                </svg>
                <span class="sidebar-label">Entidades</span>
            </a>
            <a class="sidebar-item active" href="/Perfil" title="Perfil de usuario">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 3.5h8l4 4V20.5H6Z" /><path d="M14 3.5V8h4" /><path d="M12 11v6M9 14h6" />
                </svg>
                <span class="sidebar-label">Perfíl de usuario</span>
            </a>
            <a class="sidebar-item" href="#" title="Buscar" data-wip>
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
                    <circle cx="10.5" cy="10.5" r="5.5" /><path d="m15 15 5 5" />
                </svg>
                <span class="sidebar-label">Buscar</span>
            </a>
        </nav>
    </aside>

    <div class="app-shell">
        <header class="topbar app-topbar">
            <a class="topbar-logo" href="/Perfil">
                <span class="topbar-logo-text">CEPLAN</span>
                <span class="topbar-logo-sub">Centro Nacional de Planeamiento Estratégico</span>
            </a>
            <div class="topbar-right">
                <button type="button" class="topbar-help" title="Ayuda" data-wip>?</button>
                <button type="button" class="topbar-bell" title="Notificaciones" data-wip>
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 10a6 6 0 0 1 12 0c0 4 1.5 5.5 2 6H4c.5-.5 2-2 2-6Z" /><path d="M10 19a2 2 0 0 0 4 0" />
                    </svg>
                    <span class="badge-notifications">9+</span>
                </button>
                <div class="dropdown">
                    <button type="button" class="topbar-user dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="topbar-user-avatar">
                            <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor">
                                <circle cx="12" cy="8.5" r="3.6" /><path d="M4.5 20c1.5-3.7 4.3-5.5 7.5-5.5s6 1.8 7.5 5.5v.5h-15Z" />
                            </svg>
                        </span>
                        <div class="topbar-user-info">
                            <span class="topbar-user-name">@User.Identity?.Name</span>
                            <span class="topbar-user-role">@User.FindFirstValue(SessionClaims.JobTitle)</span>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end user-menu">
                        <li>
                            <a class="dropdown-item" href="/Perfil">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
                                    <circle cx="12" cy="8.5" r="3.5" /><path d="M5 19c1.5-3.5 4-5 7-5s5.5 1.5 7 5" />
                                </svg>
                                Ver perfil
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <button type="button" class="dropdown-item user-menu-logout" id="logout-button">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 4H6v16h8" /><path d="M10 12h10" /><path d="m17 8.5 3.5 3.5-3.5 3.5" />
                                </svg>
                                Cerrar sesión
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="app-main">
            @RenderBody()
        </main>

        <footer class="brand-footer app-footer">
            <div class="brand-footer-logos">
                <div class="brand-shield" title="República del Perú"></div>
                <div class="brand-block brand-block-red">PERÚ</div>
                <div class="brand-block brand-block-dark">Presidencia<br />del Consejo de<br />Ministros</div>
                <div class="brand-block brand-block-gray">Centro Nacional<br />de Planeamiento<br />Estratégico</div>
            </div>
        </footer>
    </div>

    <partial name="_WipModal" />

    <div class="session-overlay d-none" id="session-overlay">
        <div class="session-dialog">
            <div class="session-dialog-body">
                <div class="session-dialog-icon">⚠</div>
                <div>
                    <h5 class="session-dialog-title">Su sesión esta a punto de expirar</h5>
                    <p class="session-dialog-text">
                        Por seguridad, su sesión expirará en <span id="session-countdown">60</span> segundos.
                        Para continuar, seleccione "Extender sesión"
                    </p>
                </div>
            </div>
            <div class="session-dialog-actions">
                <button type="button" class="btn btn-session-extend" id="session-extend">Extender sesión</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
