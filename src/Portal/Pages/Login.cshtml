@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="center-column">
    <div class="card-panel login-card">
        <form method="post" id="login-form" novalidate>
            <div class="doc-toggle" role="group" aria-label="Tipo de documento">
                <input type="hidden" asp-for="Input.DocumentType" id="document-type" />
                <button type="button" class="doc-toggle-option" data-doc-type="DNI">DNI</button>
                <button type="button" class="doc-toggle-option" data-doc-type="CE">CE</button>
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="Input.DocumentNumber">Usuario</label>
                <div class="field-control @(Model.UserError ? "field-invalid" : "")">
                    <span class="field-icon">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                            <circle cx="12" cy="8.5" r="3.5" />
                            <path d="M5 19c1.5-3.5 4-5 7-5s5.5 1.5 7 5" />
                        </svg>
                    </span>
                    <input asp-for="Input.DocumentNumber" id="login-user" class="field-input" placeholder="Ingresar usuario"
                           autocomplete="username" inputmode="numeric" />
                </div>
                @if (Model.UserError)
                {
                    <div class="field-error"><span class="field-error-icon">!</span> Usuario incorrecto</div>
                }
            </div>

            <div class="field-group">
                <label class="field-label" asp-for="Input.Password">Contraseña</label>
                <div class="field-control @(Model.PasswordError ? "field-invalid" : "")">
                    <span class="field-icon">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                            <rect x="5.5" y="10.5" width="13" height="9" rx="1.5" />
                            <path d="M8.5 10.5V8a3.5 3.5 0 0 1 7 0v2.5" />
                        </svg>
                    </span>
                    <input asp-for="Input.Password" id="login-password" type="password" class="field-input"
                           placeholder="Ingresar contraseña" autocomplete="current-password" />
                    <button type="button" class="field-eye" id="toggle-password" title="Mostrar contraseña">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                @if (Model.PasswordError)
                {
                    <div class="field-error"><span class="field-error-icon">!</span> Contraseña incorrecta</div>
                }
            </div>

            <a class="login-forgot" href="#" data-wip>¿Olvidó su contraseña?</a>

            <button type="submit" class="btn btn-ceplan btn-block-lg" id="login-submit" disabled>Ingresar</button>
        </form>
    </div>

    <div class="card-panel support-card">
        <span class="support-icon">
            <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="#2f6fd0" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4.5 13v-2a7.5 7.5 0 0 1 15 0v2" />
                <rect x="3" y="12.5" width="4" height="6" rx="2" fill="#e8f0fe" />
                <rect x="17" y="12.5" width="4" height="6" rx="2" fill="#e8f0fe" />
                <circle cx="12" cy="13" r="4.5" fill="#bcd4f7" stroke="none" />
                <path d="M9 21c.8.6 1.9 1 3 1" />
            </svg>
        </span>
        <p class="support-text">¿Necesita ayuda?, <a href="#" data-wip>contacte con el área de soporte</a>.</p>
    </div>
</div>

@if (Model.SessionExpired)
{
    <div class="expired-toast" id="expired-toast">
        <span class="expired-toast-icon">i</span>
        <p>Su sesión ha expirado debido a inactividad. Por favor, inicie sesión nuevamente.</p>
    </div>
}

@section Scripts {
    <script src="~/js/login.js" asp-append-version="true"></script>
}
