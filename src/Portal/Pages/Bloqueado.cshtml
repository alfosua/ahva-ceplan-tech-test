@page
@model BloqueadoModel
@{
    ViewData["Title"] = "Cuenta bloqueada";
}

<div class="center-column">
    <div class="card-panel locked-card">
        <div class="locked-illustration">
            <svg viewBox="0 0 24 24" width="84" height="84" fill="none" stroke="#2f6fd0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4.5 13v-2a7.5 7.5 0 0 1 15 0v2" />
                <rect x="3" y="12.5" width="4" height="6" rx="2" fill="#e8f0fe" />
                <rect x="17" y="12.5" width="4" height="6" rx="2" fill="#e8f0fe" />
                <circle cx="12" cy="13" r="4.5" fill="#bcd4f7" stroke="none" />
                <path d="M9 21c.8.6 1.9 1 3 1" />
            </svg>
        </div>
        <h1 class="locked-title">Cuenta bloqueada<br />temporalmemte</h1>
        <p class="locked-text">
            Has excedido el número máximo de intentos fallidos (@Model.MaxRetries).
            Por seguridad, tu cuenta ha sido bloqueada durante @Model.BanMinutes minutos.
            Intenta nuevamente más tarde.
        </p>
    </div>
</div>
